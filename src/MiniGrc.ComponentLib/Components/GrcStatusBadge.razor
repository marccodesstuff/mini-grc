@namespace MiniGrc.ComponentLib.Components

<span class="grc-badge @($"grc-badge--{Tone.ToLowerInvariant()}")" data-testid="@TestId">@Label</span>

@code {
    /// <summary>Badge text.</summary>
    [Parameter] public string Label { get; set; } = string.Empty;

    /// <summary>Color tone: success, warning, danger, neutral, info.</summary>
    [Parameter] public string Tone { get; set; } = "neutral";

    /// <summary>Stable automation selector.</summary>
    [Parameter] public string TestId { get; set; } = "grc-badge";
}
