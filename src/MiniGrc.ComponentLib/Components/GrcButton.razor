@namespace MiniGrc.ComponentLib.Components

<button class="grc-btn @($"grc-btn--{Variant.ToLowerInvariant()}")" data-testid="@TestId" @onclick="OnClick" type="@(Submit ? "submit" : "button")" disabled="@Disabled">
    @ChildContent
</button>

@code {
    /// <summary>Visual style of the button.</summary>
    [Parameter] public string Variant { get; set; } = "primary";

    /// <summary>Stable automation selector consumed by Playwright.</summary>
    [Parameter] public string TestId { get; set; } = "grc-button";

    /// <summary>Click handler.</summary>
    [Parameter] public EventCallback OnClick { get; set; }

    /// <summary>When true renders a submit button.</summary>
    [Parameter] public bool Submit { get; set; }

    /// <summary>Disables the button.</summary>
    [Parameter] public bool Disabled { get; set; }

    /// <summary>Button label/content.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }
}
