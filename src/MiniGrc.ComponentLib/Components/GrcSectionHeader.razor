@namespace MiniGrc.ComponentLib.Components

<div class="grc-section" data-testid="@TestId">
    <h2 class="grc-section__title">@Title</h2>
    @if (!string.IsNullOrWhiteSpace(Subtitle))
    {
        <p class="grc-section__subtitle">@Subtitle</p>
    }
</div>

@code {
    /// <summary>Section heading.</summary>
    [Parameter] public string Title { get; set; } = string.Empty;

    /// <summary>Optional supporting line.</summary>
    [Parameter] public string? Subtitle { get; set; }

    /// <summary>Stable automation selector.</summary>
    [Parameter] public string TestId { get; set; } = "grc-section";
}
