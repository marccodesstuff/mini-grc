@inherits LayoutComponentBase

<CascadingValue Value="Meta">
    <div class="page">
        <aside class="sidebar">
            <div class="brand">
                <div class="brand__mark" aria-hidden="true">G</div>
                <div>
                    <div class="brand__name">Mini-GRC</div>
                    <div class="brand__sub">Compliance OS</div>
                </div>
            </div>

            <NavMenu />

            <div class="sidebar__footer">
                v1.0 · Onion · CQRS<br />
                Local demo instance
            </div>
        </aside>

        <main>
            <header class="topbar">
                <div>
                    <h1 class="topbar__title" data-testid="page-title">@Meta.Title</h1>
                    <div class="topbar__crumbs" data-testid="page-crumbs">@Meta.Crumb</div>
                </div>
                <div class="topbar__right">
                    <span class="pill" data-testid="api-status"><span class="dot"></span> API online</span>
                </div>
            </header>

            <article class="content">
                @Body
            </article>
        </main>
    </div>

    <div id="blazor-error-ui" data-nosnippet>
        An unhandled error has occurred.
        <a href="." class="reload">Reload</a>
        <span class="dismiss">??</span>
    </div>
</CascadingValue>

@code {
    /// <summary>Page metadata supplied by the current page (defaults if unset).</summary>
    [CascadingParameter] public PageMeta Meta { get; set; } = PageMeta.Default;
}

