@page "/controls"
@using Augur.Web.Services
@using Augur.Web.Components.Layout
@using Augur.ComponentLib.Components
@using Augur.Application.DTOs
@inject ApiClient Api
@rendermode InteractiveServer

<CascadingValue Value="@(new PageMeta("Controls", "Control library"))">
<PageTitle>Mini-GRC · Controls</PageTitle>

<GrcSectionHeader Title="Control Library" Subtitle="Security and compliance controls across frameworks" TestId="controls-header" />

<GrcCard Title="Create Control" TestId="create-control-card">
    <div class="form-grid">
        <input class="grc-input" data-testid="input-code" @bind="NewCode" placeholder="Code (e.g. SOC2-CC6.1)" />
        <input class="grc-input" data-testid="input-title" @bind="NewTitle" placeholder="Title" />
        <input class="grc-input" data-testid="input-owner" @bind="NewOwner" placeholder="Owner" />
        <select class="grc-input" data-testid="input-framework" @bind="NewFramework">
            <option value="Soc2">SOC 2</option>
            <option value="Iso27001">ISO 27001</option>
        </select>
        <input class="grc-input" data-testid="input-description" @bind="NewDescription" placeholder="Description" />
    </div>
    <GrcButton Variant="primary" TestId="btn-create-control" OnClick="CreateAsync">Create Control</GrcButton>
    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <p class="grc-error" data-testid="controls-error">@_error</p>
    }
</GrcCard>

@if (_controls is null)
{
    <p data-testid="controls-loading">Loading controls…</p>
}
else
{
    <GrcCard Title="@($"Controls ({_controls.Count})")" TestId="controls-list">
        <table class="grc-table">
            <thead>
                <tr><th>Code</th><th>Title</th><th>Framework</th><th>Owner</th><th>Status</th><th>Evidence</th></tr>
            </thead>
            <tbody>
                @foreach (var c in _controls)
                {
                    <tr data-testid="control-row-@c.Code">
                        <td>@c.Code</td>
                        <td>@c.Title</td>
                        <td>@c.Framework</td>
                        <td>@c.Owner</td>
                        <td><GrcStatusBadge Label="@c.Status" Tone="@ToneFor(c.Status)" TestId="@($"badge-{c.Code}")" /></td>
                        <td>@c.ApprovedEvidenceCount / @c.EvidenceCount</td>
                    </tr>
                }
            </tbody>
        </table>
    </GrcCard>
}

</CascadingValue>

@code {
    private IReadOnlyList<ControlDto>? _controls;
    private string _error = string.Empty;

    private string NewCode = string.Empty;
    private string NewTitle = string.Empty;
    private string NewOwner = string.Empty;
    private string NewFramework = "Soc2";
    private string NewDescription = string.Empty;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync() => _controls = await Api.GetControlsAsync();

    private async Task CreateAsync()
    {
        _error = string.Empty;
        try
        {
            await Api.CreateControlAsync(new
            {
                code = NewCode,
                title = NewTitle,
                description = NewDescription,
                framework = NewFramework,
                owner = NewOwner
            });
            NewCode = NewTitle = NewOwner = NewDescription = string.Empty;
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private static string ToneFor(string status) => status switch
    {
        "Verified" => "success",
        "Partial" => "warning",
        "Implemented" => "info",
        "NotImplemented" => "neutral",
        _ => "neutral"
    };
}

